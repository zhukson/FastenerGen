# === LLM API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Anthropic-compatible proxy endpoint, e.g. http://host:3000
ANTHROPIC_BASE_URL=
VOYAGE_API_KEY=pa-...
GOOGLE_API_KEY=AI...

# === Database (overridden by docker-compose for local dev) ===
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5432/fastenergpt

# === Redis ===
REDIS_URL=redis://localhost:6379

# === ChromaDB ===
CHROMA_URL=http://localhost:8000

# === Object Storage (MinIO locally, GCS in prod) ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=fastenergpt

# === App Config ===
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000
