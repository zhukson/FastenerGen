FROM python:3.12-slim

WORKDIR /app

RUN pip install uv

# Install system deps needed for some packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    curl \
    libgl1 \
    libglib2.0-0 \
    libxrender1 \
    libxext6 \
    libx11-6 \
    libfontconfig1 \
    libxi6 \
    libxrandr2 \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN uv sync

ENV PYTHONPATH=/app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

EXPOSE 8080

# Hot-reload via uvicorn --reload
CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080", "--reload"]
