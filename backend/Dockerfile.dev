FROM python:3.12-slim

WORKDIR /app

RUN pip install uv

# Install system deps for drawing rasterization and Chinese font support.
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    curl \
    libgl1 \
    libglib2.0-0 \
    libxrender1 \
    libxext6 \
    libx11-6 \
    libfontconfig1 \
    fontconfig \
    fonts-dejavu-core \
    fonts-liberation \
    fonts-noto-cjk \
    fonts-wqy-zenhei \
    libxi6 \
    libxrandr2 \
    libgomp1 \
    && fc-cache -f \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN uv sync

ENV PYTHONPATH=/app
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

EXPOSE 8080

# Hot-reload via uvicorn --reload
CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080", "--reload"]
